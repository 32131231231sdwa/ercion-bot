# Токен Telegram-бота (получить у @BotFather)
BOT_TOKEN=your_bot_token_here

# ID администраторов через запятую (Telegram user IDs)
ADMIN_IDS=123456789,987654321

# Username канала (без @) для проверки подписки
CHANNEL_USERNAME=ErcionChannel

# Username для уведомлений (с @)
ADMIN_NOTIFY_USERNAME=@KrasnayaArmia

# База данных (по умолчанию SQLite)
# Для PostgreSQL: postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///ercion.db

# OpenAI API (опционально, для боевого ИИ)
# OPENAI_API_KEY=your_key_here
